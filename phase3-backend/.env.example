# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=lincesckf_db

# ── JWT ───────────────────────────────────────────────────────
# REQUIRED: Set a long random secret (e.g. openssl rand -hex 32)
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── CORS: comma-separated allowed frontend origins ───────────
CLIENT_ORIGIN=http://localhost:5173
